---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import NewsletterCTA from '../../components/sections/NewsletterCTA.astro';

const essays = (await getCollection('essays', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<PageLayout
  title="Essays"
  description="Essays on Agentic Relations — the discipline inside DevRel responsible for the AI agent layer of every developer platform. Long-form, practitioner-to-practitioner, grounded in real work."
>
  <section class="container-site pt-16 pb-8">
    <p class="eyebrow mb-4">Essays</p>
    <h1 class="max-w-3xl">The intellectual output of the Agentic Relations practice.</h1>
    <p class="lead text-muted mt-5 max-w-2xl">
      Practitioner-to-practitioner writing on where Developer Relations is going,
      why, and what to do about it. One essay per month, minimum.
    </p>
  </section>

  <section class="container-site pb-16">
    <ul class="divide-y divide-border border-t border-b border-border">
      {
        essays.map((e) => (
          <li>
            <a
              href={`/essays/${e.slug}/`}
              class="block group py-8 no-underline hover:bg-primary-surface/30 transition-colors px-2"
            >
              <div class="flex flex-col md:flex-row md:items-baseline md:gap-8">
                <p class="text-xs font-mono text-muted uppercase tracking-widest md:w-40 shrink-0 mb-2 md:mb-0">
                  {fmt(e.data.publishDate)}
                </p>
                <div class="flex-1">
                  <h2 class="text-heading text-2xl font-bold leading-tight group-hover:text-primary transition-colors">
                    {e.data.title}
                  </h2>
                  {e.data.subtitle && (
                    <p class="text-muted italic mt-2">{e.data.subtitle}</p>
                  )}
                  <p class="text-body mt-3 max-w-3xl">{e.data.description}</p>
                  <p class="text-primary font-semibold mt-4 text-sm">Read essay →</p>
                </div>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="container-site pb-20">
    <NewsletterCTA />
  </section>
</PageLayout>
