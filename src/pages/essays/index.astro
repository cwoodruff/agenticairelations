---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import NewsletterCTA from '../../components/sections/NewsletterCTA.astro';
import AgenticMark from '../../components/ui/AgenticMark.astro';

const essays = (await getCollection('essays', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<PageLayout
  title="Essays"
  description="Essays on Agentic Developer Relations — the discipline inside DevRel responsible for the AI agent layer of every developer platform. Long-form, practitioner-to-practitioner, grounded in real work."
>
  <section class="container-site pt-20 pb-12 relative overflow-hidden">
    <div
      class="absolute -right-10 top-4 opacity-[0.08] pointer-events-none hidden md:block"
      aria-hidden="true"
    >
      <AgenticMark size="xl" tone="primary" />
    </div>
    <div class="relative max-w-3xl">
      <p class="eyebrow mb-5">Essays</p>
      <h1>The intellectual output of the Agentic Developer Relations practice.</h1>
      <p class="lead text-muted mt-6 max-w-2xl">
        Practitioner-to-practitioner writing on where Developer Relations is
        going, why, and what to do about it. One essay per month, minimum.
      </p>
      <p class="mt-6 text-sm text-muted font-mono">
        <a href="/rss.xml" class="inline-flex items-center gap-2 no-underline hover:underline">
          <span aria-hidden="true">⌁</span> Subscribe via RSS
        </a>
      </p>
    </div>
  </section>

  <section class="container-site pb-16">
    <ul class="divide-y divide-border border-t border-b border-border">
      {
        essays.map((e, i) => (
          <li>
            <a
              href={`/essays/${e.slug}/`}
              class="block group py-10 md:py-12 no-underline hover:bg-primary-surface/40 transition-colors -mx-3 px-3 rounded"
            >
              <div class="flex flex-col md:flex-row md:items-baseline md:gap-10">
                <div class="md:w-44 shrink-0 mb-4 md:mb-0">
                  <p class="display-numeral text-5xl md:text-6xl">
                    {String(i + 1).padStart(2, '0')}
                  </p>
                  <p class="text-xs font-mono text-muted uppercase tracking-[0.18em] mt-3">
                    {fmt(e.data.publishDate)}
                  </p>
                </div>
                <div class="flex-1">
                  <h2 class="text-heading text-2xl md:text-3xl font-bold leading-tight group-hover:text-primary transition-colors tracking-tight">
                    {e.data.title}
                  </h2>
                  {e.data.subtitle && (
                    <p class="text-muted italic mt-3 text-lg">{e.data.subtitle}</p>
                  )}
                  <p class="text-body mt-4 max-w-3xl">{e.data.description}</p>
                  <p class="text-primary font-semibold mt-6 text-sm inline-flex items-center gap-2">
                    Read essay <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
                  </p>
                </div>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="container-site pb-24">
    <NewsletterCTA />
  </section>
</PageLayout>
