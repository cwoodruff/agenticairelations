---
import { getCollection } from 'astro:content';
import EssayLayout from '../../layouts/EssayLayout.astro';

export async function getStaticPaths() {
  const essays = await getCollection('essays', ({ data }) => !data.draft);
  return essays.map((essay) => ({
    params: { slug: essay.slug },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await essay.render();
---

<EssayLayout
  title={essay.data.title}
  subtitle={essay.data.subtitle}
  description={essay.data.description}
  publishDate={essay.data.publishDate}
  updatedDate={essay.data.updatedDate}
  tags={essay.data.tags}
  series={essay.data.series}
  seriesOrder={essay.data.seriesOrder}
  ogImage={essay.data.ogImage}
>
  <Content />
</EssayLayout>
