---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/sections/Hero.astro';
import SectionBlock from '../components/sections/SectionBlock.astro';
import SectionMarker from '../components/ui/SectionMarker.astro';
import AgenticMark from '../components/ui/AgenticMark.astro';
import EssayPreview from '../components/sections/EssayPreview.astro';
import AboutSnippet from '../components/sections/AboutSnippet.astro';
import NewsletterCTA from '../components/sections/NewsletterCTA.astro';
import FundamentalTriad from '../components/diagrams/FundamentalTriad.astro';

const principles = [
  {
    n: '01',
    title: 'The agent ecosystem is shaped by deliberate choices or by neglect.',
    body:
      'AI tools draw on whatever corpus is available — your docs, your open-source examples, your MCP servers. That corpus is being shaped right now. The only question is whether it is being shaped intentionally.',
  },
  {
    n: '02',
    title: 'Agent failures are silent and systemic.',
    body:
      'A developer whose AI tool generates a broken integration may debug silently or abandon the platform. No support ticket. No forum question. The traditional DevRel dashboard shows green while adoption degrades.',
  },
  {
    n: '03',
    title: 'Encoded judgment is the moat.',
    body:
      'AI models are commodities. What is not commoditized is encoded judgment about what a correct integration looks like. That judgment, maintained by practitioners with deep platform expertise, becomes institutional capital that compounds.',
  },
];

const pagesToRead = [
  {
    href: '/what-is-agentic-relations/',
    title: 'What Is Agentic Relations',
    body: 'The canonical definition, three principles, and how it extends the Fundamental Triad.',
    tone: 'primary',
  },
  {
    href: '/the-amdahl-tax/',
    title: 'The Amdahl Tax',
    body: 'Why the environment is the binding constraint, and what DevRel can do about it.',
    tone: 'amber',
  },
  {
    href: '/devrel-patterns-reframed/',
    title: 'The 37 Patterns Reframed',
    body: 'How every DevRel activity pattern bifurcates for the AI-agent era.',
    tone: 'purple',
  },
  {
    href: '/new-roles/',
    title: 'New Roles',
    body: 'The Agent Champion, the Documentation Architect, and the API Experience Designer.',
    tone: 'primary',
  },
  {
    href: '/measurement/',
    title: 'Measurement',
    body: 'FAISR and the four-layer Agent Ecosystem Health Dashboard.',
    tone: 'amber',
  },
];

const toneAccent: Record<string, string> = {
  primary: 'border-t-primary',
  amber: 'border-t-amber',
  purple: 'border-t-purple',
};
---

<PageLayout
  title="Agentic Relations"
  description="Agentic Relations is the discipline inside Developer Relations responsible for the AI agent layer of every developer platform. The canonical reference, by Chris Woodruff."
>
  <Hero
    eyebrow="A new discipline inside Developer Relations"
    headline="When a developer asks AI to integrate with your platform, does it work?"
    highlight="does it work?"
    subheadline="Most DevRel programs don't know. Agentic Relations is the discipline that makes the answer knowable — and then systematically improves it."
    ctaPrimary={{ href: '/what-is-agentic-relations/', label: 'What is Agentic Relations?' }}
    ctaSecondary={{ href: '/essays/', label: 'Read the essays' }}
  />

  <!-- The problem statement — color-blocked primary teal -->
  <SectionBlock tone="primary">
    <div class="container-site py-20 md:py-28 relative">
      <div
        class="absolute right-4 top-10 opacity-15 pointer-events-none hidden md:block"
        aria-hidden="true"
      >
        <AgenticMark size="xl" tone="onDark" />
      </div>
      <div class="max-w-3xl relative">
        <p
          class="font-mono text-xs font-bold uppercase mb-5 tracking-[0.2em] text-white/80 inline-flex items-center gap-3"
        >
          <span class="w-4 h-[2px] bg-white/80" aria-hidden="true"></span>
          The problem
        </p>
        <h2 class="text-white text-3xl md:text-5xl font-bold leading-[1.1] tracking-tight mb-8">
          The developer community has a new member.
        </h2>
        <div class="space-y-5 text-lg leading-relaxed text-white/92">
          <p>
            It doesn't attend your conferences. It doesn't read your blog posts.
            It doesn't care about your ambassador program. But it touches every
            integration your platform hosts, amplifies every ambiguity in your
            documentation, and makes a decision about your platform on behalf
            of every developer who asks it to write some code.
          </p>
          <p>
            That member is the AI coding agent. And Developer Relations, as a
            field, has no framework for serving it.
          </p>
          <p class="text-2xl md:text-3xl font-bold text-white pt-4">
            Agentic Relations is that framework.
          </p>
        </div>
      </div>
    </div>
  </SectionBlock>

  <!-- The extended triad -->
  <section class="section container-site">
    <SectionMarker numeral="01" eyebrow="The Fundamental Triad, extended" />
    <div class="max-w-2xl mb-6">
      <h2>One platform. Two audiences. A missing framework.</h2>
      <p class="text-muted mt-5 text-lg leading-relaxed">
        The original Fundamental Triad of Developer Relations — Community,
        Company, Customer — assumed every vertex was human. That assumption
        has broken. Each vertex now has an agent-era extension.
      </p>
    </div>
    <FundamentalTriad />
  </section>

  <!-- Three principles — color-blocked purple -->
  <SectionBlock tone="purple">
    <div class="container-site py-20 md:py-28">
      <div class="max-w-2xl mb-14">
        <p class="font-mono text-xs font-bold uppercase mb-4 tracking-[0.2em] text-white/80 inline-flex items-center gap-3">
          <span class="w-4 h-[2px] bg-white/80" aria-hidden="true"></span>
          02 · Three principles
        </p>
        <h2 class="text-white text-3xl md:text-5xl font-bold leading-[1.08] tracking-tight">
          What Agentic Relations assumes about the world.
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {
          principles.map((p) => (
            <div class="rounded-2xl p-7 bg-white/10 backdrop-blur border border-white/15 text-white">
              <p class="font-mono text-white/70 font-bold text-sm mb-4 tracking-[0.18em]">
                {p.n}
              </p>
              <h3 class="text-white text-xl font-bold mb-4 leading-snug tracking-tight">
                {p.title}
              </h3>
              <p class="text-white/85 text-[0.95rem] leading-relaxed">{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </SectionBlock>

  <!-- Five pages worth reading first -->
  <section class="section container-site">
    <SectionMarker numeral="03" eyebrow="Start here" />
    <div class="max-w-2xl mb-10">
      <h2>Five pages worth reading first.</h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        pagesToRead.map((p) => (
          <a
            href={p.href}
            class:list={[
              'group block border-t-4 border-x border-b border-border rounded-xl p-7 bg-surface hover:shadow-card-hover shadow-card transition-all no-underline hover:-translate-y-0.5',
              toneAccent[p.tone],
            ]}
          >
            <h3 class="text-heading text-lg font-bold mb-3 group-hover:text-primary transition-colors leading-snug">
              {p.title}
            </h3>
            <p class="text-muted text-sm leading-relaxed">{p.body}</p>
            <p class="text-primary font-semibold text-sm mt-5 inline-flex items-center gap-2">
              Read <span class="transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <EssayPreview />

  <AboutSnippet />

  <!-- Newsletter — color-blocked amber for a warm close -->
  <SectionBlock tone="amber">
    <div class="container-site py-20 md:py-24 relative">
      <div
        class="absolute -right-8 top-8 opacity-20 pointer-events-none"
        aria-hidden="true"
      >
        <AgenticMark size="xl" tone="onDark" />
      </div>
      <div class="max-w-3xl relative">
        <p class="font-mono text-xs font-bold uppercase mb-5 tracking-[0.2em] text-white/85 inline-flex items-center gap-3">
          <span class="w-4 h-[2px] bg-white/85" aria-hidden="true"></span>
          The Agentic Relations Brief
        </p>
        <h2 class="text-white text-3xl md:text-4xl font-bold leading-[1.12] tracking-tight">
          New frameworks, delivered twice a month.
        </h2>
        <p class="text-white/92 mt-5 text-lg leading-relaxed max-w-2xl">
          One original observation, one annotated link, one action item — for
          DevRel practitioners working through the agent era.
        </p>
        <a
          href="/newsletter/"
          class="inline-flex items-center gap-2 mt-8 px-7 py-3.5 font-semibold rounded-md bg-white text-amber no-underline hover:bg-white/95 transition-colors shadow-card"
        >
          Subscribe <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </SectionBlock>
</PageLayout>
