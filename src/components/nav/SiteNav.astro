---
import Wordmark from '../ui/Wordmark.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';

const pathname = Astro.url.pathname;

const links = [
  { href: '/what-is-agentic-relations/', label: 'What Is It' },
  { href: '/devrel-patterns-reframed/', label: 'The Patterns' },
  { href: '/new-roles/', label: 'New Roles' },
  { href: '/measurement/', label: 'Measurement' },
  { href: '/essays/', label: 'Essays' },
  { href: '/about/', label: 'About' },
];

const isActive = (href: string) =>
  pathname === href || pathname === href.replace(/\/$/, '');
---

<header
  class="border-b border-border bg-bg/85 backdrop-blur sticky top-0 z-40 transition-colors"
>
  <div class="container-site flex items-center justify-between py-4 gap-4">
    <Wordmark />

    <nav class="hidden md:flex items-center gap-1" aria-label="Primary">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              'relative px-3 py-2 text-sm no-underline transition-colors',
              isActive(l.href)
                ? 'text-primary font-semibold'
                : 'text-body hover:text-primary',
            ]}
          >
            {l.label}
            {isActive(l.href) && (
              <span
                class="absolute left-3 right-3 -bottom-[17px] h-[2px] bg-primary"
                aria-hidden="true"
              />
            )}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle />

      <details class="md:hidden relative">
        <summary
          class="list-none cursor-pointer p-2 text-heading"
          aria-label="Open menu"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </summary>
        <nav
          class="absolute right-0 mt-2 w-64 bg-surface border border-border rounded-lg shadow-card p-2 flex flex-col z-50"
          aria-label="Mobile"
        >
          {
            links.map((l) => (
              <a
                href={l.href}
                class:list={[
                  'px-3 py-2 text-sm rounded-md no-underline',
                  isActive(l.href)
                    ? 'text-primary font-semibold bg-primary-surface'
                    : 'text-body hover:bg-primary-surface/60',
                ]}
              >
                {l.label}
              </a>
            ))
          }
        </nav>
      </details>
    </div>
  </div>
</header>
