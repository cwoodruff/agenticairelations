---
import AgenticMark from '../ui/AgenticMark.astro';
import Wordmark from '../ui/Wordmark.astro';

const year = new Date().getFullYear();

const groups = [
  {
    heading: 'Read',
    links: [
      { href: '/what-is-agentic-relations/', label: 'What Is Agentic Relations' },
      { href: '/the-amdahl-tax/', label: 'The Amdahl Tax' },
      { href: '/devrel-patterns-reframed/', label: 'The 37 Patterns Reframed' },
      { href: '/new-roles/', label: 'New Roles' },
      { href: '/measurement/', label: 'Measurement' },
    ],
  },
  {
    heading: 'Apply',
    links: [
      { href: '/for-devrel-teams/', label: 'For DevRel Teams' },
      { href: '/for-companies/', label: 'For Companies' },
      { href: '/essays/', label: 'Essays' },
      { href: '/newsletter/', label: 'Newsletter' },
      { href: '/rss.xml', label: 'RSS feed' },
    ],
  },
  {
    heading: 'About',
    links: [
      { href: '/about/', label: 'Chris Woodruff' },
      { href: '/about/#speaking', label: 'Speaking' },
      { href: 'https://ecosynt.io', label: 'EcoSynt', external: true },
    ],
  },
];
---

<footer class="relative border-t border-border bg-surface mt-24 overflow-hidden">
  <!-- Faint backdrop glyph — sits behind content, decorative only. -->
  <div class="absolute -right-16 -bottom-24 opacity-[0.05] pointer-events-none" aria-hidden="true">
    <AgenticMark size="xl" tone="primary" />
  </div>

  <div class="container-site py-16 relative">
    <div class="grid md:grid-cols-4 gap-10">
      <div class="md:col-span-1">
        <Wordmark />
        <p class="text-muted text-sm mt-5 leading-relaxed">
          The canonical reference for the discipline of Agentic Relations —
          where Developer Relations meets the AI-agent era.
        </p>
      </div>

      {
        groups.map((g) => (
          <div>
            <h3 class="text-heading text-xs font-mono font-bold uppercase tracking-widest mb-4">
              {g.heading}
            </h3>
            <ul class="space-y-2.5">
              {g.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class="text-body hover:text-primary text-[0.92rem] no-underline transition-colors"
                    {...(l.external ? { target: '_blank', rel: 'noopener' } : {})}
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-14 pt-8 border-t border-border flex flex-col md:flex-row justify-between items-start md:items-center gap-4 text-sm text-muted">
      <p>&copy; {year} Chris Woodruff. All rights reserved.</p>
      <p class="font-mono text-xs">agenticairelations.com</p>
    </div>
  </div>
</footer>
