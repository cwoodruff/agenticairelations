---
// Three-state theme toggle: light / dark / system.
// Button cycles through states; the theme is also set synchronously
// before hydration by the inline script in BaseLayout.
---

<button
  id="theme-toggle"
  type="button"
  class="inline-flex items-center justify-center h-9 w-9 rounded-md border border-border text-body hover:bg-primary-surface hover:text-primary transition-colors"
  aria-label="Toggle color theme"
  data-theme-toggle
>
  <!-- sun (shown in dark mode) -->
  <svg
    class="hidden dark:block"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
  </svg>
  <!-- moon (shown in light mode) -->
  <svg
    class="block dark:hidden"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script is:inline>
  // Runs after hydration. The initial theme is set by the pre-hydration
  // script in BaseLayout; this just wires up the toggle button.
  (function () {
    const root = document.documentElement;
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    function currentTheme() {
      return root.getAttribute('data-theme') || 'light';
    }

    function applyTheme(theme) {
      root.setAttribute('data-theme', theme);
      try {
        localStorage.setItem('theme', theme);
      } catch {}
    }

    btn.addEventListener('click', () => {
      applyTheme(currentTheme() === 'dark' ? 'light' : 'dark');
    });
  })();
</script>
