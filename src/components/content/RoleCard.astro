---
interface Props {
  title: string;
  also?: string;
  color?: 'primary' | 'purple' | 'amber';
}

const { title, also, color = 'primary' } = Astro.props;

const borderColor = {
  primary: 'border-t-primary',
  purple: 'border-t-purple',
  amber: 'border-t-amber',
};
---

<article
  class={`border-t-4 ${borderColor[color]} border-x border-b border-border rounded-lg bg-surface p-6 shadow-sm h-full`}
>
  {also && <p class="text-muted text-xs font-mono uppercase tracking-wide mb-2">{also}</p>}
  <h3 class="text-heading text-xl font-bold mb-4">{title}</h3>
  <div class="text-body leading-relaxed">
    <slot />
  </div>
</article>
