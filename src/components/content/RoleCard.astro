---
interface Props {
  title: string;
  also?: string;
  color?: 'primary' | 'purple' | 'amber';
}

const { title, also, color = 'primary' } = Astro.props;

const borderColor = {
  primary: 'border-t-primary',
  purple: 'border-t-purple',
  amber: 'border-t-amber',
};

const titleColor = {
  primary: 'text-primary',
  purple: 'text-purple',
  amber: 'text-amber',
};
---

<article
  class:list={[
    'group border-t-4',
    borderColor[color],
    'border-x border-b border-border rounded-lg bg-surface p-6 shadow-card hover:shadow-card-hover transition-shadow h-full',
  ]}
>
  {also && <p class="text-muted text-[0.7rem] font-mono uppercase tracking-[0.18em] mb-3">{also}</p>}
  <h3 class:list={['text-xl font-bold mb-4 leading-snug', titleColor[color]]}>{title}</h3>
  <div class="text-body leading-relaxed">
    <slot />
  </div>
</article>
