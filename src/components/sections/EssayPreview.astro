---
import { getCollection } from 'astro:content';

const all = await getCollection('essays', ({ data }) => !data.draft);
const essays = all
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<section class="container-site section">
  <div class="flex items-end justify-between mb-12 flex-wrap gap-4">
    <div>
      <p class="eyebrow mb-4">Essays</p>
      <h2 class="max-w-2xl">Read the argument, one essay at a time.</h2>
    </div>
    <a
      href="/essays/"
      class="text-primary font-semibold hover:underline no-underline inline-flex items-center gap-2"
      >View all essays <span aria-hidden="true">→</span></a
    >
  </div>

  <div class="grid md:grid-cols-3 gap-6">
    {
      essays.map((e, i) => (
        <a
          href={`/essays/${e.slug}/`}
          class:list={[
            'group block border border-border rounded-2xl p-7 bg-surface hover:border-primary transition-all no-underline shadow-card hover:shadow-card-hover hover:-translate-y-0.5',
          ]}
        >
          <p class="text-xs text-muted font-mono uppercase tracking-widest mb-4">
            <span class="text-primary font-bold mr-3">{String(i + 1).padStart(2, '0')}</span>
            {fmt(e.data.publishDate)}
          </p>
          <h3 class="text-heading text-lg font-bold leading-snug mb-3 group-hover:text-primary transition-colors">
            {e.data.title}
          </h3>
          <p class="text-muted text-sm leading-relaxed">{e.data.description}</p>
          <p class="text-primary font-semibold text-sm mt-5 inline-flex items-center gap-2">
            Read essay <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
          </p>
        </a>
      ))
    }
  </div>
</section>
