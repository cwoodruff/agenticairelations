---
import { getCollection } from 'astro:content';

const all = await getCollection('essays', ({ data }) => !data.draft);
const essays = all
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<section class="container-site section">
  <div class="flex items-end justify-between mb-10 flex-wrap gap-4">
    <div>
      <p class="eyebrow mb-2">Essays</p>
      <h2 class="text-heading">Read the argument, one essay at a time.</h2>
    </div>
    <a
      href="/essays/"
      class="text-primary font-semibold hover:underline">View all essays →</a
    >
  </div>

  <div class="grid md:grid-cols-3 gap-6">
    {
      essays.map((e) => (
        <a
          href={`/essays/${e.slug}/`}
          class="group block border border-border rounded-xl p-6 bg-surface hover:border-primary transition-colors no-underline"
        >
          <p class="text-xs text-muted font-mono mb-3">
            {fmt(e.data.publishDate)}
          </p>
          <h3 class="text-heading text-lg font-bold leading-snug mb-3 group-hover:text-primary transition-colors">
            {e.data.title}
          </h3>
          <p class="text-muted text-sm leading-relaxed">{e.data.description}</p>
          <p class="text-primary font-semibold text-sm mt-4">Read essay →</p>
        </a>
      ))
    }
  </div>
</section>
