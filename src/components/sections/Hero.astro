---
import AgenticMark from '../ui/AgenticMark.astro';

interface Props {
  eyebrow?: string;
  headline: string;
  subheadline?: string;
  ctaPrimary?: { href: string; label: string };
  ctaSecondary?: { href: string; label: string };
  /** Show a stylised highlight on part of the headline. Split the headline
   *  on this string and wrap the matched segment in a teal underline. */
  highlight?: string;
}

const { eyebrow, headline, subheadline, ctaPrimary, ctaSecondary, highlight } =
  Astro.props;

// Split the headline around `highlight` (case-insensitive) so we can wrap
// the accent portion in a teal-underlined span without inner HTML injection.
function splitHeadline(h: string, needle: string | undefined) {
  if (!needle) return [h];
  const idx = h.toLowerCase().indexOf(needle.toLowerCase());
  if (idx === -1) return [h];
  return [h.slice(0, idx), h.slice(idx, idx + needle.length), h.slice(idx + needle.length)];
}

const parts = splitHeadline(headline, highlight);
---

<section
  class="relative overflow-hidden border-b border-border"
>
  <!-- faint grid backdrop -->
  <div
    class="absolute inset-0 hero-grid opacity-70 pointer-events-none"
    aria-hidden="true"
  ></div>
  <!-- giant signature glyph, lower-right, faded -->
  <div
    class="absolute -right-16 -bottom-32 md:-right-12 md:-bottom-20 opacity-[0.08] pointer-events-none"
    aria-hidden="true"
  >
    <AgenticMark size="xl" tone="primary" animated />
  </div>
  <!-- radial wash -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(90% 70% at 20% 0%, rgb(var(--color-primary) / 0.06) 0%, transparent 60%);"
    aria-hidden="true"
  ></div>

  <div class="container-site relative py-24 md:py-32">
    {
      eyebrow && (
        <p class="eyebrow mb-6 reveal reveal-1">{eyebrow}</p>
      )
    }

    <h1 class="max-w-[22ch] font-bold tracking-tight reveal reveal-2">
      {parts.length === 3 ? (
        <>
          {parts[0]}
          <span class="relative inline-block">
            <span class="relative z-10">{parts[1]}</span>
            <span
              class="absolute left-0 right-0 bottom-1 md:bottom-2 h-3 md:h-4 bg-primary/25 -z-0"
              aria-hidden="true"
            />
          </span>
          {parts[2]}
        </>
      ) : (
        parts[0]
      )}
    </h1>

    {
      subheadline && (
        <p class="lead mt-8 max-w-2xl text-muted reveal reveal-3">
          {subheadline}
        </p>
      )
    }

    {
      (ctaPrimary || ctaSecondary) && (
        <div class="mt-10 flex flex-wrap gap-3 reveal reveal-4">
          {ctaPrimary && (
            <a
              href={ctaPrimary.href}
              class="inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold rounded-md bg-primary text-primary-ink hover:bg-primary-light no-underline transition-colors shadow-card"
            >
              {ctaPrimary.label}
            </a>
          )}
          {ctaSecondary && (
            <a
              href={ctaSecondary.href}
              class="inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold rounded-md bg-surface text-primary border border-primary hover:bg-primary-surface no-underline transition-colors"
            >
              {ctaSecondary.label}
            </a>
          )}
        </div>
      )
    }
  </div>
</section>
