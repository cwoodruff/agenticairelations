---
import PageLayout from './PageLayout.astro';
import NewsletterCTA from '../components/sections/NewsletterCTA.astro';

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  publishDate: Date;
  updatedDate?: Date;
  tags?: string[];
  series?: string;
  seriesOrder?: number;
  ogImage?: string;
}

const { title, subtitle, description, publishDate, updatedDate, tags, ogImage } =
  Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<PageLayout title={title} description={description} ogType="article" ogImage={ogImage}>
  <article class="py-12 md:py-20">
    <header class="container-prose mb-10">
      <p class="eyebrow mb-4">Essay</p>
      <h1 class="mb-4">{title}</h1>
      {subtitle && <p class="lead text-muted italic">{subtitle}</p>}
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted mt-6 font-mono">
        <time datetime={publishDate.toISOString()}>{fmt(publishDate)}</time>
        {
          updatedDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>Updated {fmt(updatedDate)}</span>
            </>
          )
        }
        {
          tags && tags.length > 0 && (
            <>
              <span aria-hidden="true">·</span>
              <span>{tags.join(' · ')}</span>
            </>
          )
        }
      </div>
    </header>

    <div class="container-prose prose prose-lg max-w-[70ch]">
      <slot />
    </div>

    <div class="container-site mt-16">
      <NewsletterCTA />
    </div>
  </article>
</PageLayout>
